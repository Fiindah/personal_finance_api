# --- Laravel Core ---
/vendor/
node_modules/
.env
.env.backup
.env.production
# composer.lock dan package-lock.json dihapus dari sini agar ikut ter-upload

# --- Storage & Cache ---
/storage/*.key
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/bootstrap/cache/*

# --- Public Assets ---
/public/hot
/public/storage
/public/build
npm-debug.log
yarn-error.log

# --- Database (SQLite) ---
# Mengabaikan database lokal agar tidak menimpa database di server
*.sqlite
*.sqlite-journal

# --- Testing ---
.phpunit.result.cache
.phpunit.cache/